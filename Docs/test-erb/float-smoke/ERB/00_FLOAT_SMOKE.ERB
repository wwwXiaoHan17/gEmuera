; Float Smoke Test
; Purpose: verify DIMF, FUNCTIONF, LOCALF, ARGF, RESULTF, TOSTRF.
; Expected output (first screen):
;   === FLOAT SMOKE ===
;   PASS: DIMF default and assign
;   1.250000
;   PASS: FUNCTIONF return
;   2.500000
;   PASS: LOCALF
;   3.750000
;   PASS: ARGF
;   5.000000
;   PASS: RESULTF
;   6.250000
;   PASS: TOSTRF math
;   1.000000
;   [WAIT prompt]

@EVENTFIRST
PRINTL === FLOAT SMOKE ===
CALL FLOAT_BASIC
CALL FLOAT_FUNC
CALL FLOAT_LOCALF
CALL FLOAT_ARGF
CALL FLOAT_RESULTF
CALL FLOAT_MATH
PRINTL PASS: float smoke finished
WAIT
RETURN 0

@FLOAT_BASIC
#DIMF X
X = 1.25
PRINTL PASS: DIMF default and assign
PRINTVL TOSTRF(X)
RETURN 0

@FLOAT_FUNC
#FUNCTIONF
#DIMF ARG
RETURNF ARG:0 * 1.25

@FLOAT_LOCALF
#DIMF LOCALF_X
LOCALF_X = 3.75
PRINTL PASS: LOCALF
PRINTVL TOSTRF(LOCALF_X)
RETURN 0

@FLOAT_ARGF
#FUNCTIONF
#DIMF ARGF
PRINTL PASS: ARGF
PRINTVL TOSTRF(ARGF:0)
RETURNF ARGF:0

@FLOAT_RESULTF
#FUNCTIONF
RESULTF = 6.25
PRINTL PASS: RESULTF
PRINTVL TOSTRF(RESULTF)
RETURNF RESULTF

@FLOAT_MATH
PRINTL PASS: TOSTRF math
PRINTVL TOSTRF(SIN(1.5707963267948966))
RETURN 0
