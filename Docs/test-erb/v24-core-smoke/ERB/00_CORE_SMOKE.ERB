#DIMF CORE_INITF = 1.5, 2.25
#DIMF SAVEDATA CORE_SAVEF, 3
#DIMS CORE_STR = "base"

@EVENTFIRST
PRINTL === V24 CORE SMOKE ===
CALL CORE_FLOAT_SMOKE
CALL CORE_FLOAT_MATH_SMOKE
CALL CORE_HEADER_REF_SMOKE
CALL CORE_SCALAR_REF_SMOKE
CALL CORE_ARRAY_REF_SMOKE
CALL CORE_REF_SIGNATURE_SMOKE
CALL CORE_CALL_SMOKE
CALL CORE_COMPAT_PARSE_SMOKE
CALL CORE_ERD_SMOKE
CALL CORE_MAP_SMOKE
CALL CORE_XML_SMOKE
CALL CORE_DT_SMOKE
CALL CORE_SAVEVAR_SMOKE
CALL CORE_SQL_SMOKE
PRINTL PASS: v24 core smoke finished
WAIT
RETURN 0

@CORE_FLOAT_SMOKE
#DIMF X
#DIM VSE, 2, 3
X = 1.25
PRINTL PASS: DIMF parsed
PRINTSL PASS: TOSTRF=
PRINTVL TOSTRF(X)
PRINTSL PASS: DIMF default=
PRINTVL TOSTRF(CORE_INITF:0)
PRINTVL TOSTRF(CORE_INITF:1)
PRINTSL PASS: DIMF SAVEDATA assign=
CORE_SAVEF:0 = 6.75
PRINTVL TOSTRF(CORE_SAVEF:0)
PRINTSL PASS: CALLF=
PRINTVL TOSTRF(CALLF(TEST_FLOAT, 2))
PRINTSL PASS: SETVARF=
PRINTVL SETVAR("X", 3.5, 0)
PRINTVL TOSTRF(GETVARF("X"))
PRINTSL PASS: VARSETEXF=
PRINTVL VARSETEX("X", 4.5, 0)
PRINTVL TOSTRF(GETVARF("X"))
PRINTSL PASS: GETVAR default mismatch=
PRINTVL GETVAR("X", 99)
PRINTSL PASS: GETVARS default mismatch=
PRINTSL GETVARS("X", "fallback")
PRINTSL PASS: GETVARF default missing=
PRINTVL TOSTRF(GETVARF("NO_SUCH_FLOAT", 2.25))
PRINTSL PASS: VARSETEX indexed row=
PRINTVL VARSETEX("VSE:1:1", 5, 0)
PRINTVL VSE:1:2
PRINTSL PASS: VARSETEX indexed all=
PRINTVL VARSETEX("VSE:1:0", 10)
PRINTVL VSE:0:0
PRINTVL VSE:1:2
RETURN 0

@CORE_ERD_SMOKE
PRINTSL PASS: ERD GETNUM=
PRINTVL GETNUM(ERDTEST, "ALPHA")
PRINTSL PASS: ERDNAME=
PRINTSL ERDNAME(ERDTEST, 2)
RETURN 0

@TEST_FLOAT
#FUNCTIONF
#DIM ARG
RETURNF ARG:0 + 0.5

@CORE_FLOAT_MATH_SMOKE
PRINTSL PASS: SIN=
PRINTVL TOSTRF(SIN(1.5707963267948966))
PRINTSL PASS: FLOOR=
PRINTVL TOSTRF(FLOOR(1.9))
PRINTSL PASS: CEIL=
PRINTVL TOSTRF(CEIL(1.1))
PRINTSL PASS: ROUND=
PRINTVL TOSTRF(ROUND(1.5))
RETURN 0

@CORE_HEADER_REF_SMOKE
REF HEADER_FLOAT, TEST_FLOAT
PRINTSL PASS: ERH FUNCTIONF REF=
PRINTVL TOSTRF(HEADER_FLOAT(2))
RETURN 0

@CORE_SCALAR_REF_SMOKE
#DIM LOCAL_REF_SRC
#REF LOCAL_INT_REF
LOCAL_REF_SRC = 21
REF LOCAL_INT_REF, LOCAL_REF_SRC
LOCAL_INT_REF += 1
PRINTSL PASS: local #REF scalar=
PRINTVL LOCAL_REF_SRC
REF HEADER_INT_REF, CORE_SAVEF
PRINTSL PASS: ERH #REF mismatch=
PRINTVL RESULT
REF HEADER_FLOAT_REF, CORE_SAVEF
HEADER_FLOAT_REF = 8.25
PRINTSL PASS: ERH #REFF scalar=
PRINTVL TOSTRF(CORE_SAVEF:0)
REF HEADER_STR_REF, CORE_STR
HEADER_STR_REF = "changed"
PRINTSL PASS: ERH #REFS scalar=
PRINTSL CORE_STR
RETURN 0

@CORE_ARRAY_REF_SMOKE
#DIM ARRAY_REF_SRC, 3
#DIMF ARRAY_FLOAT_REF_SRC, 3
#DIMS ARRAY_STR_REF_SRC, 3
ARRAY_REF_SRC:1 = 42
ARRAY_FLOAT_REF_SRC:1 = 4.25
ARRAY_STR_REF_SRC:1 = "array-ref"
REF HEADER_INT_ARRAY_REF, ARRAY_REF_SRC
REF HEADER_FLOAT_ARRAY_REF, ARRAY_FLOAT_REF_SRC
REF HEADER_STR_ARRAY_REF, ARRAY_STR_REF_SRC
PRINTSL PASS: ERH #DIM REF array=
PRINTVL HEADER_INT_ARRAY_REF:1
PRINTVL TOSTRF(HEADER_FLOAT_ARRAY_REF:1)
PRINTSL HEADER_STR_ARRAY_REF:1
RETURN 0

@CORE_REF_SIGNATURE_SMOKE
#DIM OUTBUF, 1
REF HEADER_VARIADIC, TEST_VARIADIC
PRINTSL PASS: ERH FUNCTION variadic ref=
PRINTVL HEADER_VARIADIC(1, 2, 3, 4)
REF HEADER_OUT, TEST_OUT_REF
PRINTSL PASS: ERH FUNCTION OUT ref bind=
PRINTVL RESULT
PRINTSL PASS: ERH FUNCTION OUT ref call=
PRINTVL HEADER_OUT(OUTBUF)
PRINTVL OUTBUF:0
RETURN 0

@CORE_CALL_SMOKE
CALLSTR "CORE_CALL_TARGET"
PRINTSL PASS: variadic argc=
PRINTVL CALL(TEST_VARIADIC, 1, 2, 3)
PRINTSL PASS: getargcount argc=
PRINTVL CALL(TEST_GETARGCOUNT, 1, 2, 3, 4)
RETURN 0

@CORE_CALL_TARGET
PRINTL PASS: CALLSTR target reached
RETURN 0

@CORE_COMPAT_PARSE_SMOKE
#DIMS DYNAMIC out
out = "dynamic-out"
PRINTSL PASS: DYNAMIC out local=
PRINTSL out
RETURN 0

@CORE_COMPAT_LOAD_ONLY_SMOKE
#DIMS EVALS
TOOLTIP_CUSTOM 1
TOOLTIP_SETFONTSIZE 12
TOOLTIP_FORMAT 0
TOOLTIP_IMG 0
TOOLTIP_SETFONT "Arial"
BINPUT
BINPUTS
ONEBINPUT
ONEBINPUTS
RETURN 0

@TEST_VARIADIC
#FUNCTION
#DIM VARIADIC ARG
RETURN ARGLEN()

@TEST_GETARGCOUNT
#FUNCTION
#DIM VARIADIC ARG
RETURN GETARGCOUNT()

@TEST_OUT_REF
#FUNCTION
#DIM OUT ARG
ARG:0 = 33
RETURN ARG:0

@CORE_MAP_SMOKE
PRINTSL PASS: MAP_CREATE=
PRINTVL MAP_CREATE("m")
PRINTSL PASS: MAP_SET=
PRINTVL MAP_SET("m", "k", "v")
PRINTSL PASS: MAP_GET=
PRINTSL MAP_GET("m", "k")
RETURN 0

@CORE_XML_SMOKE
PRINTSL PASS: XML_DOCUMENT=
PRINTVL XML_DOCUMENT("x", "<root><n>1</n></root>")
PRINTSL PASS: XML_SET=
PRINTVL XML_SET("x", "/root/n", "2")
PRINTSL PASS: XML_TOSTR=
PRINTSL XML_TOSTR("x")
RETURN 0

@CORE_DT_SMOKE
PRINTSL PASS: DT_CREATE=
PRINTVL DT_CREATE("dt")
PRINTSL PASS: DT_COLUMN_ADD=
PRINTVL DT_COLUMN_ADD("dt", "value", "float")
PRINTSL PASS: DT_ROW_ADD=
PRINTVL DT_ROW_ADD("dt", "value", 2.5)
PRINTSL PASS: DT_CELL_GETF=
PRINTVL TOSTRF(DT_CELL_GETF("dt", 0, "value"))
RETURN 0

@CORE_SAVEVAR_SMOKE
CORE_SAVEF:0 = 12.5
CORE_STR = "saved-var"
SAVEVAR "core_smoke_var", "core smoke var", CORE_SAVEF, CORE_STR
CORE_SAVEF:0 = 0
CORE_STR = "reset"
LOADVAR "core_smoke_var"
PRINTSL PASS: SAVEVAR LOADVAR RESULT=
PRINTVL RESULT
PRINTSL PASS: SAVEVAR LOADVAR float=
PRINTVL TOSTRF(CORE_SAVEF:0)
PRINTSL PASS: SAVEVAR LOADVAR str=
PRINTSL CORE_STR
RETURN 0

@CORE_SQL_SMOKE
PRINTSL PASS: SQL_OPEN=
PRINTVL SQL_CONNECTION_OPEN("core_smoke")
PRINTSL PASS: SQL_CREATE=
PRINTVL SQL_EXECUTE_NONQUERY("core_smoke", "CREATE TABLE IF NOT EXISTS t (id INTEGER, value REAL)")
PRINTSL PASS: SQL_INSERT=
PRINTVL SQL_EXECUTE_NONQUERY("core_smoke", "INSERT INTO t (id, value) VALUES (1, 1.5)")
RETURN 0
